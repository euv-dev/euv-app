{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "allow-load-cached-resource",
    "allow-resolve-bridge-group-permissions"
  ],
  "platforms": ["android", "linux", "macOS", "windows"],
  "remote": {
    "urls": ["http://*", "https://*"]
  }
}
